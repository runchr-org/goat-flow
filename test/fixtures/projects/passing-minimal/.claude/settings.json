{
  "permissions": {
    "deny": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(chmod 777*)",
      "Bash(curl *| bash*)",
      "Bash(wget *| sh*)",
      "Read(.env*)",
      "Read(.ssh/**)",
      "Read(.aws/**)",
      "Read(**/*.pem)",
      "Read(**/credentials*)",
      "Edit(.env*)",
      "Write(.env*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/stop-lint.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/format-file.sh" }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "compact",
        "hooks": [
          { "type": "command", "command": "echo compact" }
        ]
      }
    ]
  }
}
