{
  // Gemini CLI settings template - copy to .gemini/settings.json
  // Gemini uses different event names than Claude Code:
  //   Claude PreToolUse  = Gemini BeforeTool
  //   Claude PostToolUse = Gemini AfterTool
  //   Claude Stop        = Gemini AfterAgent
  //
  // The hook scripts are the same - only the registration event names differ.

  // --- Permissions Deny List ---------------------------------------------------
  "permissions": {
    "deny": [
      "Bash(*git commit*)",
      "Bash(*git push*)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/credentials*)"
    ]
  },

  // --- Hook Registrations ------------------------------------------------------
  "hooks": {
    // BeforeTool: fires BEFORE the tool executes. Exit 2 = block.
    // Equivalent to Claude's PreToolUse.
    "BeforeTool": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.gemini/hooks/deny-dangerous.sh\""
          }
        ]
      }
    ]
  }
}
