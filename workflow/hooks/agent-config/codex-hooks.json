{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/deny-destructive-commands.sh\"",
            "statusMessage": "Deny destructive commands"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/deny-secret-access.sh\"",
            "statusMessage": "Deny secret access"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/deny-git-mutations.sh\"",
            "statusMessage": "Deny git mutations"
          }
        ]
      }
    ]
  }
}
