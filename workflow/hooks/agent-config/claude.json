{
  "permissions": {
    "allow": [
      "Read(.env.example)",
      "Read(**/.env.example)"
    ],
    "deny": [
      "Bash(*git commit*)",
      "Bash(*git push*)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/credentials*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/deny-dangerous.sh\""
          }
        ]
      }
    ]
  }
}
