{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".goat-flow/hooks/deny-dangerous.sh",
            "statusMessage": "Deny dangerous hook"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".goat-flow/hooks/gruff-code-quality.sh",
            "statusMessage": "gruff code quality"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".goat-flow/hooks/gruff-code-quality.sh",
            "statusMessage": "gruff code quality"
          }
        ]
      }
    ]
  }
}
