{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/guard-destructive-shell.sh",
            "statusMessage": "Guard destructive shell"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/guard-secret-paths.sh",
            "statusMessage": "Guard secret paths"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/guard-repository-writes.sh",
            "statusMessage": "Guard repository writes"
          }
        ]
      }
    ]
  }
}
