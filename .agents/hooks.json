{
  "deny-destructive-commands": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/deny-destructive-commands.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "deny-secret-access": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command|view_file|write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/deny-secret-access.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "deny-git-mutations": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/deny-git-mutations.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
