{
  "guard-destructive-shell": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/guard-destructive-shell.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "guard-secret-paths": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command|view_file|write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/guard-secret-paths.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "guard-repository-writes": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/guard-repository-writes.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
